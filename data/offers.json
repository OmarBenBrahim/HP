{
  "html": {
    "productSummary": "<h1 class=\"visually-hidden\" id=\"product-summary-title\">Product summary</h1><div class=\"product-summary__layout\"><div class=\"product-summary__group\"><div class=\"product-summary__media\"><img class=\"product-summary__image\" src=\"{{image.src}}\" alt=\"{{image.alt}}\"></div><div class=\"product-summary__content\"><div class=\"product-summary__selector-row\"><span class=\"product-summary__selector-label\" id=\"serial-selector-label\">{{selectorLabel}}</span><div class=\"selector selector--single js-selector\" data-selected-value=\"{{selectedSerial}}\"><button class=\"selector__trigger js-selector-trigger\" type=\"button\" aria-haspopup=\"listbox\" aria-expanded=\"false\" aria-labelledby=\"serial-selector-label serial-selector-value\"><span class=\"selector__value\" id=\"serial-selector-value\">{{selectedSerial}}</span><span class=\"selector__chevron\" aria-hidden=\"true\"></span></button><ul class=\"selector__menu js-selector-menu\" role=\"listbox\" aria-labelledby=\"serial-selector-label\">{{{selectorOptionsHtml}}}</ul></div></div><dl class=\"product-summary__details\">{{{detailsHtml}}}</dl></div></div></div>",
    "carouselTile": "<article class=\"tile tile--carousel js-track-tile\" data-offer-id=\"{{id}}\" data-component-type=\"carousel\" tabindex=\"0\"><div class=\"tile__body tile__body--carousel\"><img class=\"tile__icon\" src=\"{{icon.src}}\" alt=\"{{icon.alt}}\"><h3 class=\"tile__title tile__title--carousel\">{{title}}</h3><p class=\"tile__description tile__description--carousel\">{{description}}</p><a class=\"button button--primary tile__button\" href=\"{{button.href}}\" data-track-click=\"true\">{{button.label}}</a></div></article>",
    "smallOfferTile": "<article class=\"tile tile--small-offer js-track-tile\" data-offer-id=\"{{id}}\" data-component-type=\"small-offer\" tabindex=\"0\"><div class=\"tile__media tile__media--small\"><img class=\"tile__image\" src=\"{{image.src}}\" alt=\"{{image.alt}}\"></div><div class=\"tile__body tile__body--small\"><h3 class=\"tile__title tile__title--small\">{{title}}</h3><p class=\"tile__description tile__description--small\">{{description}}</p><a class=\"button button--primary tile__button\" href=\"{{button.href}}\" data-track-click=\"true\">{{button.label}}</a></div></article>",
    "skuOfferTile": "<article class=\"tile tile--sku-offer js-track-tile\" data-offer-id=\"{{id}}\" data-component-type=\"sku-offer\" tabindex=\"0\"><div class=\"tile__media tile__media--sku\"><img class=\"tile__image\" src=\"{{image.src}}\" alt=\"{{image.alt}}\"></div><div class=\"tile__body tile__body--sku\"><p class=\"tile__pill\">{{pill.label}}</p><p class=\"tile__description tile__description--sku\">{{description}}</p><div class=\"tile__price-row\"><span class=\"tile__price tile__price--strike\">{{strikePrice}}</span><span class=\"tile__price tile__price--sale\">{{salePrice}}</span></div><a class=\"button button--secondary tile__button\" href=\"{{button.href}}\" data-track-click=\"true\">{{button.label}}</a></div></article>",
    "bannerTile": "<article class=\"tile tile--banner js-track-tile\" data-offer-id=\"{{id}}\" data-component-type=\"banner\" tabindex=\"0\"><div class=\"tile__media tile__media--banner\"><img class=\"tile__image\" src=\"{{image.src}}\" alt=\"{{image.alt}}\"></div><div class=\"tile__body tile__body--banner\"><h3 class=\"tile__title tile__title--banner\">{{title}}</h3><p class=\"tile__description tile__description--banner\">{{description}}</p><a class=\"button button--primary tile__button\" href=\"{{button.href}}\" data-track-click=\"true\">{{button.label}}</a></div></article>",
    "stickyFooter": "<div class=\"sticky-footer\" data-footer-id=\"{{id}}\"><div class=\"sticky-footer__content\"><p class=\"sticky-footer__title\">{{title}}</p><a class=\"button button--primary sticky-footer__button\" href=\"{{button.href}}\">{{button.label}}</a></div><button class=\"sticky-footer__close\" type=\"button\" aria-label=\"{{closeLabel}}\"><span class=\"sticky-footer__close-icon\" aria-hidden=\"true\"></span></button></div>"
  },
